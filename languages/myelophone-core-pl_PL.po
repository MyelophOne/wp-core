#: includes/Admin/InfoPage.php:698
msgid "Core plugin for WordPress optimization and management. Provides essential tools for site performance, security, and maintenance."
msgstr "Podstawowa wtyczka do optymalizacji i zarządzania WordPress. Zapewnia niezbędne narzędzia do wydajności, bezpieczeństwa i konserwacji strony."

#: includes/Admin/InfoPage.php:708
msgid "Security"
msgstr "Bezpieczeństwo"

#: includes/Admin/InfoPage.php:714
msgid "Protect your site with security headers, version hiding, and REST API restrictions."
msgstr "Chroń swoją stronę za pomocą nagłówków bezpieczeństwa, ukrywania wersji i ograniczeń REST API."

#: includes/Admin/InfoPage.php:724
msgid "Performance"
msgstr "Wydajność"

#: includes/Admin/InfoPage.php:730
msgid "Disable unnecessary features, remove old revisions monthly, and clean up for faster loading."
msgstr "Wyłącz niepotrzebne funkcje, usuwaj stare wersje miesięcznie i czyść, aby przyspieszyć ładowanie."

#: includes/Admin/InfoPage.php:740
msgid "Maintenance"
msgstr "Konserwacja"

#: includes/Admin/InfoPage.php:746
msgid "Manage post revisions, clean up comments, and optimize database automatically."
msgstr "Zarządzaj wersjami wpisów, czyść komentarze i optymalizuj bazę danych automatycznie."

